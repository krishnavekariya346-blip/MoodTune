<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".MoodTuneApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MoodTune"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- Login Activity (from AudiusDatabase) -->
        <activity
            android:name=".auth.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Home Page Activity -->
        <activity
            android:name=".home.HomePageActivity"
            android:exported="false" />

        <!-- Face Detection Activity -->
        <activity
            android:name=".face.FaceDetectionActivity"
            android:exported="false" />

        <!-- Mood Selection Activity (from AudiusDatabase) -->
        <activity
            android:name=".music.MoodSelectionActivity"
            android:exported="false" />

        <!-- Song Recommendation Activity (from AudiusDatabase) -->
        <activity
            android:name=".music.HomeActivity"
            android:exported="false" />

        <!-- Chatbot Activity (from MoodTune_c_main_db_login) -->
        <activity
            android:name=".chatbot.ChatbotActivity"
            android:exported="false" />

        <!-- Settings Activity -->
        <activity
            android:name=".settings.SettingsActivity"
            android:exported="false" />

        <!-- Edit Profile Activity -->
        <activity
            android:name=".settings.EditProfileActivity"
            android:exported="false" />

        <!-- Change Password Activity -->
        <activity
            android:name=".settings.ChangePasswordActivity"
            android:exported="false" />

        <!-- About Activity -->
        <activity
            android:name=".settings.AboutActivity"
            android:exported="false" />

        <!-- Module 4 - Daily Report -->
        <activity
            android:name=".reports.DailyReportActivity"
            android:exported="false" />

        <!-- Module 4 - Weekly Report -->
        <activity
            android:name=".reports.WeeklyReportActivity"
            android:exported="false" />

        <!-- Module 4 - Monthly Report -->
        <activity
            android:name=".reports.MonthlyReportActivity"
            android:exported="false" />

    </application>

</manifest>

