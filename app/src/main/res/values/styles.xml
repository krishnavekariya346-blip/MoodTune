<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.MoodTune.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_marginHorizontal">16dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.02</item>
    </style>
    
    <style name="Widget.MoodTune.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_marginHorizontal">16dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="strokeWidth">2dp</item>
    </style>
    
    <style name="Widget.MoodTune.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:layout_height">56dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="Widget.MoodTune.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">20dp</item>
        <item name="boxCornerRadiusTopEnd">20dp</item>
        <item name="boxCornerRadiusBottomStart">20dp</item>
        <item name="boxCornerRadiusBottomEnd">20dp</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/md_theme_onSurfaceVariant</item>
        <item name="android:textColorHint">@color/md_theme_onSurfaceVariant</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="Widget.MoodTune.TextInputEditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
    </style>
    
    <style name="Widget.MoodTune.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/md_theme_surface</item>
        <item name="strokeWidth">0dp</item>
    </style>
    
    <style name="Widget.MoodTune.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/md_theme_surface</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/md_theme_outline</item>
    </style>
    
    <style name="Widget.MoodTune.Dialog" parent="ThemeOverlay.Material3.Dialog">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowAnimationStyle">@style/Animation.MoodTune.Dialog</item>
    </style>
    
    <style name="Widget.MoodTune.TextView.Title" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/md_theme_onSurface</item>
        <item name="android:letterSpacing">0.01</item>
    </style>
    
    <style name="Widget.MoodTune.TextView.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/md_theme_onSurface</item>
    </style>
    
    <style name="Widget.MoodTune.TextView.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/md_theme_onSurface</item>
    </style>
    
    <style name="Widget.MoodTune.TextView.Hint" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/md_theme_onSurfaceVariant</item>
        <item name="android:alpha">0.7</item>
    </style>
    
    <style name="Animation">
    </style>
    
    <style name="Animation.MoodTune" parent="Animation">
    </style>
    
    <style name="Animation.MoodTune.Dialog" parent="Animation.MoodTune">
        <item name="android:windowEnterAnimation">@anim/slide_up_fade_in</item>
        <item name="android:windowExitAnimation">@anim/slide_down_fade_out</item>
    </style>
    
    <style name="Animation.MoodTune.Screen" parent="Animation.MoodTune">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>
</resources>

